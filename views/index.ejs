<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= duck? `${duck.name} - ` :"" %>ECTS CMP Ducks!</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous" />
  <link rel="stylesheet" href="/css/style.css" />
  <% if(duck){ %>
  <script>
    window.PRELOADED_DUCK = <%- JSON.stringify(duck) %>;
    window.SINGLE_DUCK_MODE = true
  </script>
  <%}%>
  </head>
  <body>
    <div class="container" id="main_container">
      <% if(duck){ %>
  <h1 class="mb-4"><%= duck.name %></h1>
  <%}%>
        <% if(errorMessage){ %>
  <div class="alert alert-warning" role="alert"><%= errorMessage %></div>
  <%}%>
  <% if(!duck){ %>

  <div class="mb-3">
    <label for="duckSelect" class="form-label">Please select a duck</label>
    <select id="duckSelect" name="duckSelect" class="form-select" aria-label="Default select example" placehoder="Select a duck">
      <option selected disabled>Please Select a Duck</option>
    </select>
  </div>
  <%}%>
      <div class="row">
        <div class="col-md-6">
          <div id="ThreeDuck" class="waiting">
            <img src="/images/Loading_Duck 1.gif" id="loading_img" alt="" />
            <div class="placeholder">Please select a duck to load</div>
          </div>
        </div>
        <div class="col-md-6" id="duck_info_container">
          <div id="id_row" class="d-flex align-items-center gap-2 flex-wrap">
            <div class="stat_text">ID</div>
            <div class="flex-grow-1 info-cell">
              <span class="stat_val_span"></span>
            </div>
          </div>
          <div id="name_row" class="d-flex align-items-center gap-2 flex-wrap">
            <div class="stat_text">Name</div>
            <div class="flex-grow-1 info-cell">
              <span class="stat_val_span"></span>
            </div>
          </div>

          <div
            id="assembler_row"
            class="d-flex align-items-center gap-2 flex-wrap"
          >
            <div class="stat_text">Assembler</div>
            <div class="flex-grow-1 info-cell">
              <span class="stat_val_span"></span>
            </div>
          </div>
          <div
            id="adjectives_row"
            class="d-flex align-items-center gap-2 flex-wrap"
          >
            <div class="stat_text">Adjectives</div>
            <div class="flex-grow-1 info-cell">
              <span class="stat_val_span"></span>
            </div>
          </div>
          <div id="bio_row" class="d-flex align-items-center gap-2 flex-wrap">
            <div class="stat_text">Bio</div>
            <div class="flex-grow-1 info-cell">
              <span class="stat_val_span"></span>
            </div>
          </div>

          <div
            id="strength_bar"
            class="d-flex align-items-center gap-2 flex-wrap"
          >
            <div class="stat_text">Strength</div>
            <div class="progress flex-grow-1">
              <div
                class="progress-bar bg-warning"
                role="progressbar"
                style="width: 0%"
              >
                <span class="stat_val_span"></span>
              </div>
            </div>
          </div>
          <div
            id="health_bar"
            class="d-flex align-items-center gap-2 flex-wrap"
          ><div class="stat_text">Health</div>
            <div class="progress flex-grow-1">
              <div
                class="progress-bar bg-primary"
                role="progressbar"
                style="width: 0%"
              >
                <span class="stat_val_span"></span>
              </div>
            </div>
          </div>
          <div
            id="intelligence_bar"
            class="d-flex align-items-center gap-2 flex-wrap"
          >
            <div class="stat_text">Intelligence</div>
            <div class="progress flex-grow-1">
              <div
                class="progress-bar bg-success"
                role="progressbar"
                style="width: 0%"
              >
                <span class="stat_val_span"></span>
              </div>
            </div>
          </div>

          <div id="focus_bar" class="d-flex align-items-center gap-2 flex-wrap">
            <div class="stat_text">Focus</div>
            <div class="progress flex-grow-1">
              <div
                class="progress-bar bg-danger"
                role="progressbar"
                style="width: 0%"
              >
                <span class="stat_val_span"></span>
              </div>
            </div>
          </div>
          <div
            id="kindness_bar"
            class="d-flex align-items-center gap-2 flex-wrap"
          >
            <div class="stat_text">Kindness</div>
            <div class="progress flex-grow-1">
              <div
                class="progress-bar bg-info"
                role="progressbar"
                style="width: 0%"
              >
                <span class="stat_val_span"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="row mt-4" id="chat_section" style="display: none">
        <div class="col-12">
          <div class="card">
            <div class="card-header">Duck Chat</div>
            <div id="startChatDiv">
              <button id="startChatButton" class="btn btn-primary w-100">
                Start Chat
              </button>
            </div>
            <div class="card-body" id="chatBody">
              <div id="chat_messages"></div>

              <form id="chat_form" class="d-flex gap-2">
                <input
                  type="text"
                  id="chat_input"
                  class="form-control"
                  placeholder="Ask the duck something..."
                />
                <button type="submit" class="btn btn-primary">Send</button>
              </form>
              <div class="alert alert-danger mt-3 py-2 small">
                <strong>Disclaimer:</strong> This AI is for entertainment purposes only. Do not share
                                personal or sensitive information. Responses
                                will often be intentionally inaccurate and
                                should not be taken as advice or relied upon for
                                decisions.
                </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script type="importmap">
      {
        "imports": {
          "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
          "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
        }
      }
    </script>

    <script type="module" src="/js/app.js"></script>
  </body>
</html>
